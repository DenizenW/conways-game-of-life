{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@conways-game-of-life/source"],
    "baseUrl": ".",
    "paths": {
      "@conways-game-of-life/api-client": ["libs/api-client/src/index.ts"],
      "@conways-game-of-life/sim": ["libs/sim/src/index.ts"],
      "@conways-game-of-life/types": ["libs/types/src/index.ts"],
      "@conways-game-of-life/ui": ["libs/ui/src/index.ts"]
    }
  }
}
