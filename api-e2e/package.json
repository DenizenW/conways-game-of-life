{
  "name": "@conways-game-of-life/api-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "tags": ["scope:e2e"],
    "implicitDependencies": [
      "@conways-game-of-life/api"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "api-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@conways-game-of-life/api:build",
          "@conways-game-of-life/api:serve"
        ]
      }
    }
  }
}
